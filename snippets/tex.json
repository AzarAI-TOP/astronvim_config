{
  "template-notes": {
    "prefix": "template-notes",
    "body": [
      "%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%% Notes %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%",
      "\\documentclass{article}",
      "%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%% Used Packages %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%",
      "\\usepackage{NotesTeXV3}",
      "\\usepackage{xeCJK}",
      "%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%% Fonts %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%",
      "\\setCJKmainfont{Source Han Serif SC}",
      "\\setCJKsansfont{Source Han Sans HW SC}",
      "\\setCJKmonofont{Source Han Mono SC}",
      "%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%% Cover %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%",
      "\title{$1}",
      "\\author{AzarAI}",
      "\\emailAdd{azarai@mail.ustc.edu.cn}",
      "\\date{${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DAY}}",
      "%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%% Notes %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%",
      "\\begin{document}",
      "\\maketitle",
      "",
      "$2",
      "",
      "\\end{document}"
    ],
    "description": "Template for latex note-taking for NotesTexV3 template",
    "luasnip": {
      "priority": 2000,
      "autotrigger": true,
      "wordTrig": true
    }
  },
